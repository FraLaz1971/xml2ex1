Here's your corrected code with proper element access and file handling:

```c
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <png.h>

int main(int argc, char** argv) {
    int x, y, pos;
    FILE *fp;
    FILE *ofp;
    png_structp png;
    png_infop info;
    char ifname[256];
    char ofname[256];
    char base[256];
    char *result_ptr;
    int width;
    int height;
    png_byte color_type;
    png_byte bit_depth;
    png_bytep *rows;
    
    if(argc < 2) {
        fprintf(stderr, "Usage: %s <file.png>\n", argv[0]);
        return 1;
    }
    
    strcpy(ifname, argv[1]);
    fp = fopen(ifname, "rb");
    if(!fp) { 
        perror("fopen"); 
        return 1; 
    }

    png = png_create_read_struct(PNG_LIBPNG_VER_STRING, NULL, NULL, NULL);
    if(!png) return 1;
    
    info = png_create_info_struct(png);
    if(!info) return 1;
    
    if(setjmp(png_jmpbuf(png))) return 1;

    png_init_io(png, fp);
    png_read_info(png, info);

    width = png_get_image_width(png, info);
    height = png_get_image_height(png, info);
    color_type = png_get_color_type(png, info);
    bit_depth = png_get_bit_depth(png, info);

    if (color_type != PNG_COLOR_TYPE_GRAY || bit_depth != 8) {
        fprintf(stderr, "Expected 8-bit grayscale image\n");
        return 1;
    }

    // Allocate memory for row pointers
    rows = (png_bytep*)malloc(sizeof(png_bytep) * height);
    for(y = 0; y < height; y++) {
        rows[y] = (png_byte*)malloc(png_get_rowbytes(png, info));
    }

    png_read_image(png, rows);

    printf("Read grayscale image %dx%d\n", width, height);
    
    // Example: Access and print some pixels
    printf("Example pixels:\n");
    printf("  Top-left (0,0): %3d\n", rows[0][0]);
    printf("  Center (%d,%d): %3d\n", width/2, height/2, rows[height/2][width/2]);
    printf("  Bottom-right (%d,%d): %3d\n", width-1, height-1, rows[height-1][width-1]);
    
    // Access ALL pixels
    printf("\nAccessing all pixels:\n");
    for(y = 0; y < height; y++) {
        for(x = 0; x < width; x++) {
            png_byte pixel = rows[y][x];
            // Process pixel here - for example, you could:
            // - Write to another file
            // - Perform image processing
            // - Convert to ASCII art, etc.
        }
    }

    // Create output filename
    result_ptr = strstr(ifname, ".");
    pos = result_ptr - ifname;
    strncpy(base, ifname, pos);
    base[pos] = '\0';
    snprintf(ofname, sizeof(ofname), "%s.asc", base);
    fprintf(stderr, "Output file name: %s\n", ofname);
    
    // Open output file for writing (was incorrectly using input file)
    ofp = fopen(ofname, "w");
    if(!ofp) {
        perror("fopen output");
        return 1;
    }
    
    // Example: Write pixel values to output file
    for(y = 0; y < height; y++) {
        for(x = 0; x < width; x++) {
            fprintf(ofp, "%3d ", rows[y][x]);
        }
        fprintf(ofp, "\n");
    }
    
    // Cleanup
    fclose(ofp);
    for(y = 0; y < height; y++) {
        free(rows[y]);
    }
    free(rows);
    fclose(fp);
    png_destroy_read_struct(&png, &info, NULL);
    
    return 0;
}
```

**Key improvements:**

1. **Proper element access**: Use `rows[y][x]` where `y` is the row index (0 to height-1) and `x` is the column index (0 to width-1)

2. **Fixed file handling**: 
   - Use `ofp` for output file instead of reusing `fp`
   - Proper error checking for output file

3. **Complete pixel iteration**: The nested loops show how to access every pixel

4. **Type safety**: Added proper casting for malloc calls

**Memory layout visualization:**
```
rows[0] → [pixel(0,0)][pixel(0,1)]...[pixel(0,width-1)]
rows[1] → [pixel(1,0)][pixel(1,1)]...[pixel(1,width-1)]
...
rows[height-1] → [pixel(height-1,0)]...[pixel(height-1,width-1)]
```

This structure gives you efficient random access to any pixel using `rows[y][x]`.
